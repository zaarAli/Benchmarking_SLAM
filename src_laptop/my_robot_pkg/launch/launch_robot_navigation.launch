<?xml version="1.0"?>
<launch>


<!-- keyboard control 
  <node name="key_control" pkg="warehouse_simulation" type="key_control" respawn="false" output="screen"/>
-->
<!-- Arguments -->
  <arg name="scan_topic"     default="/scan"/>


  <!-- AMCL -->
  <node pkg="amcl" type="amcl" name="amcl">

    <param name="initial_pose_x" value="-2.0"/>
    <param name="initial_pose_y" value="0.0"/>
    <param name="initial_pose_a" value="0.0"/>
    <param name="min_particles"             value="500"/>
    <param name="max_particles"             value="3000"/>
    <param name="kld_err"                   value="0.02"/>
    <param name="update_min_d"              value="0.20"/>
    <param name="update_min_a"              value="0.20"/>
    <param name="resample_interval"         value="1"/>
    <param name="transform_tolerance"       value="1"/>
    <param name="recovery_alpha_slow"       value="0.00"/>
    <param name="recovery_alpha_fast"       value="0.00"/>
    <param name="gui_publish_rate"          value="50.0"/>
    <param name="transform_tolerance" value="1.0" />
    <!-- <remap from="scan"                      to="$(arg scan_topic)"/> -->
    <param name="laser_max_range"           value="3.5"/>
    <param name="laser_max_beams"           value="180"/>
    <param name="laser_z_hit"               value="0.5"/>
    <param name="laser_z_short"             value="0.05"/>
    <param name="laser_z_max"               value="0.05"/>
    <param name="laser_z_rand"              value="0.5"/>
    <param name="laser_sigma_hit"           value="0.2"/>
    <param name="laser_lambda_short"        value="0.1"/>
    <param name="laser_likelihood_max_dist" value="2.0"/>
    <param name="laser_model_type"          value="likelihood_field"/>

    <param name="odom_model_type"           value="diff"/>
  
    <param name="odom_frame_id"             value="odom"/>
    <param name="base_frame_id"             value="base_footprint"/>
    <param name="min_particle_cloud_update_frequency" value="10.0" />
    <param name="max_particle_cloud_update_frequency" value="50.0" />
    <param name="use_map_topic" value="true"/>
    <param name="first_sensor_timeout" value="5.0"/>
    <param name="tf_buffer_duration" value="10.0"/>

  </node>

 <node pkg="move_base" type="move_base" name="move_base" output="screen">
    <rosparam file="$(find my_robot_pkg)/params/costmap_common_params.yaml" command="load" ns="global_costmap" />
    <rosparam file="$(find my_robot_pkg)/params/costmap_common_params.yaml" command="load" ns="local_costmap" />
    <rosparam file="$(find my_robot_pkg)/params/local_costmap_params.yaml" command="load" ns="local_costmap" />
    <rosparam file="$(find my_robot_pkg)/params/global_costmap_params.yaml" command="load" ns="global_costmap" />
    <rosparam file="$(find my_robot_pkg)/params/base_local_planner_params.yaml" command="load" />
    <param name="transform_tolerance" value="1.0"/>
    <param name="tf_buffer_duration" value="10.0"/>  <!-- Default is 10s, increase if needed -->
  </node>


  <node pkg="rviz" type="rviz" name="rviz" args="-d $(find warehouse_simulation)/rviz/navigation.rviz" output="screen"/>

</launch>

  