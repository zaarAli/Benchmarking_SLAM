
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="robot">

  <xacro:macro name="robot" params="">

    <!-- Define robot properties -->
    <xacro:property name="robot_name" value="robot"/>

    <!-- Include RPLIDAR sensor -->
    <xacro:include filename="$(find new_robot)/urdf/rplidar.xacro"/>

    <!-- Define robot links -->
    <link name="base_footprint"/>
    
    
	<joint name="base_footprint_to_base_link" type="fixed">
	  <parent link="base_footprint"/>
	  <child link="base_link"/>
	  <origin xyz="0 0 0.05" rpy="0 0 0"/>
	</joint>

    <link name="base_link">
      <visual>
        <geometry>
          <box size="0.31 0.25 0.14"/>
        </geometry>
        <material name="red">
          <color rgba="1 0 0 1"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <box size="0.31 0.25 0.14"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="5.0"/>
        <origin xyz="0 0 0.07"/>
        <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
      </inertial>
    </link>

    <!-- Define wheels -->
    <xacro:macro name="wheel_link" params="name">
      <link name="${name}">
        <visual>
          <geometry>
            <cylinder radius="0.0325" length="0.027"/>
          </geometry>
          <origin xyz="0 0 0" rpy="1.5708 0 0"/>
          <material name="yellow">
            <color rgba="1 1 0 1"/>
          </material>
        </visual>
        <collision>
          <geometry>
            <cylinder radius="0.0325" length="0.027"/>
          </geometry>
          <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        </collision>
        <inertial>
          <mass value="0.5"/>
          <origin xyz="0 0 0"/>
          <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
        </inertial>
      </link>
    </xacro:macro>

    <xacro:wheel_link name="wheel_front_left"/>
    <xacro:wheel_link name="wheel_front_right"/>
    <xacro:wheel_link name="wheel_back_left"/>
    <xacro:wheel_link name="wheel_back_right"/>

    <!-- Wheel joints -->
    <joint name="joint_wheel_front_left" type="continuous">
      <parent link="base_link"/>
      <child link="wheel_front_left"/>
      <origin xyz="0.12 0.125 -0.0325" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>

    <joint name="joint_wheel_front_right" type="continuous">
      <parent link="base_link"/>
      <child link="wheel_front_right"/>
      <origin xyz="0.12 -0.125 -0.0325" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>

    <joint name="joint_wheel_back_left" type="continuous">
      <parent link="base_link"/>
      <child link="wheel_back_left"/>
      <origin xyz="-0.12 0.125 -0.0325" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>

    <joint name="joint_wheel_back_right" type="continuous">
      <parent link="base_link"/>
      <child link="wheel_back_right"/>
      <origin xyz="-0.12 -0.125 -0.0325" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>

    <!-- Add transmissions for the wheels -->
    <xacro:macro name="wheel_transmission" params="joint_name motor_name">
      <transmission name="trans_${joint_name}">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="${joint_name}"/>
        <actuator name="${motor_name}">
          <hardwareInterface>EffortJointInterface</hardwareInterface>
        </actuator>
      </transmission>
    </xacro:macro>

    <xacro:wheel_transmission joint_name="joint_wheel_front_left"  motor_name="motor_wheel_front_left"/>
    <xacro:wheel_transmission joint_name="joint_wheel_front_right" motor_name="motor_wheel_front_right"/>
    <xacro:wheel_transmission joint_name="joint_wheel_back_left"   motor_name="motor_wheel_back_left"/>
    <xacro:wheel_transmission joint_name="joint_wheel_back_right"  motor_name="motor_wheel_back_right"/>

  </xacro:macro>

  <!-- IMU setup -->
  <link name="imu_link"/>
  <joint name="base_to_imu" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.07" rpy="0 0 0"/>
  </joint>

</robot>
