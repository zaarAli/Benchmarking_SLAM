<launch>
  <!-- ======================== -->
  <!-- Load Robot Description  -->
  <!-- ======================== -->
  <!-- Load the URDF (via Xacro) into the parameter server -->
  <param name="robot_description" command="$(find xacro)/xacro '$(find new_robot)/urdf/robot.urdf'" />

  <!-- ================================= -->
  <!-- Robot State and Joint Publishers -->
  <!-- ================================= -->

  
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher">
  <param name="publish_frequency" value="50.0"/> 
  </node>
  
  
  <!-- ====================== -->
  <!-- Serial Connection Node -->
  <!-- ====================== -->
  <!-- Communicates with Arduino over serial for motor data, encoders, etc. -->
  <node pkg="rosserial_python" type="serial_node.py" name="serial_node">
    <param name="port" value="/dev/serial/by-id/usb-www.Arduino.cc_Arduino_14011-if00"/>
    <param name="baud" value="115200"/>
  </node>

  <!-- ==================== -->
  <!-- IMU Sensor Pipeline  -->
  <!-- ==================== -->
  <!-- Raw IMU data publisher (MPU6050 driver) -->
  <node name="imu_node" pkg="mpu_6050_driver" type="imu_node.py" />


  <!-- ==================== -->
  <!-- RPLIDAR Configuration -->
  <!-- ==================== -->
  <!-- Publishes /scan topic for LIDAR data used in mapping or obstacle avoidance -->
  <node name="rplidarNode" pkg="rplidar_ros" type="rplidarNode" output="screen">
    <param name="serial_port" type="string" value="/dev/serial/by-id/usb-Silicon_Labs_CP2102_USB_to_UART_Bridge_Controller_0001-if00-port0"/>
    <param name="serial_baudrate"     type="int"    value="115200"/> <!-- A1/A2 models -->
    <param name="frame_id"            type="string" value="rplidar_link"/>
    <param name="inverted"            type="bool"   value="false"/>
    <param name="angle_compensate"    type="bool"   value="true"/>
  </node>

  <!-- ======================= -->
  <!-- RViz and Interaction   -->
  <!-- ======================= -->
  <!-- RViz for visualizing robot, map, and TF -->


  <!-- Listen to clicked points in RViz and publish 2D poses -->
  <!-- Publishes: /initial_2d and /goal_2d -->
  <node pkg="localization_data_pub" type="rviz_click_to_2d" name="rviz_click_to_2d" />

  <!-- ================================== -->
  <!-- Odometry and Sensor Fusion Setup  -->
  <!-- ================================== -->
  <!-- Publishes wheel odometry based on encoder ticks -->
  <!-- Subscribes to: /left_ticks, /right_ticks, /initial_2d -->
  <!-- Publishes: /odom_data_euler, /odom_data_quat -->
  <node pkg="localization_data_pub" type="ekf_odom_pub" name="ekf_odom_pub" />
  
  <node pkg="rf2o_laser_odometry" type="rf2o_laser_odometry_node" name="rf2o_laser_odometry" output="screen" >
    <param name="laser_scan_topic" value="/scan"/>
    <param name="odom_topic" value="/odom_rf2o"/>
    <param name="publish_tf" value="true"/>
    <param name="base_frame_id" value="base_footprint"/>
    <param name="odom_frame_id" value="odom"/>
    <param name="init_pose_from_topic" value=""/>
    <param name="freq" value="7.0"/>
    <param name="verbose" value="true"/>
    <remap from="odom_rf2o" to="/odom" />
  </node>

  
    <!-- Map File -->
  <arg name="map_file" default="$(find launch_pi_nano_bot)/maps/room.yaml"/>
	
  <!-- Map Server -->
  <!-- Publish: /map, /map_metadata -->
  <node pkg="map_server" name="map_server" type="map_server" args="$(arg map_file)" />
	


</launch>

